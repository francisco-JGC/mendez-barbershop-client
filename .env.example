# URL base que usa el navegador para llamar a la API. Por defecto las
# llamadas van a /api y el dev server de Vite las reenvía al backend
# (ver VITE_API_PROXY_TARGET abajo). En producción, si el frontend se
# sirve desde el mismo dominio que el backend, deja esto vacío para
# usar rutas relativas /api.
# VITE_API_BASE_URL=/api

# Solo para desarrollo local (no afecta el build de producción):
# A dónde reenvía Vite las peticiones /api.
VITE_API_PROXY_TARGET=http://localhost:3000

# El backend es multitenant: identifica la barbería por el código que
# el usuario escribe en el login (campo "Código de establecimiento"),
# no por dominio/subdominio. No hace falta configurar nada aquí para
# eso — el código se guarda en el navegador después de iniciar sesión.
